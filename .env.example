# Firebase (Vite에서 사용하므로 VITE_ 접두사 필수)
# 로컬: .env에 값 입력. 배포: 넷리파이 환경 변수에 동일 이름으로 추가
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Netlify Functions 전용 (넷리파이 대시보드 → Site settings → Environment variables 에만 설정)
# 로컬 netlify dev 사용 시 .env에 넣으면 함수에서 읽음
OPENAI_API_KEY=
BAREUN_API_KEY=

# Google Drive 폴더 연동 (참고 자료 자동 불러오기용). 서비스 계정 JSON 전체를 한 줄 문자열로 넣기
# 사용 전: Google Cloud에서 Drive API 사용 설정, 서비스 계정 생성 후 키 JSON 다운로드
# 참고할 폴더를 서비스 계정 이메일(xxx@project.iam.gserviceaccount.com)과 "뷰어"로 공유해야 함
# GOOGLE_SERVICE_ACCOUNT_JSON=
